# Copy to `infra/docker/.env` next to `docker-compose.yml` for variable substitution
# when using: docker compose -f infra/docker/docker-compose.yml ...

SPRING_APPLICATION_NAME=smpp-observability-platform

SERVER_PORT=8080

SMPP_SERVER_ENABLED=true
SMPP_SERVER_HOST=0.0.0.0
SMPP_SERVER_PORT=2775
SMPP_SERVER_MAX_CONNECTIONS=256
SMPP_SERVER_IO_THREADS=32
SMPP_SERVER_CLOSE_SCHEDULER_THREADS=1
SMPP_SERVER_SYSTEM_ID=SMPP
SMPP_SERVER_ACCEPT_ANY_BIND=true
SMPP_SERVER_EXPECTED_SYSTEM_ID=
SMPP_SERVER_EXPECTED_PASSWORD=

SMPP_THROTTLE_ENABLED=true
SMPP_THROTTLE_MAX_TPS_PER_SYSTEM_ID=1000

# Queue handoff + topology
SMPP_QUEUE_ENABLED=true
SMPP_QUEUE_EXCHANGE=smpp.direct
SMPP_QUEUE_NAME=smpp.messages.process
SMPP_QUEUE_ROUTING_KEY=messages.process
SMPP_QUEUE_HANDOFF_INTERVAL_MS=500
SMPP_QUEUE_BATCH_SIZE=50
SMPP_QUEUE_DLX_EXCHANGE=smpp.dlx
SMPP_QUEUE_RETRY_ROUTING_KEY=messages.process.retry
SMPP_QUEUE_DLQ_ROUTING_KEY=messages.process.dlq
SMPP_QUEUE_RETRY_NAME=smpp.messages.process.retry
SMPP_QUEUE_DLQ_NAME=smpp.messages.process.dlq
SMPP_QUEUE_MESSAGE_RETRY_TTL_MS=2000

POSTGRES_DB=smpp
POSTGRES_USER=smpp
POSTGRES_PASSWORD=smpp

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/smpp
SPRING_DATASOURCE_USERNAME=smpp
SPRING_DATASOURCE_PASSWORD=smpp

SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest
SPRING_RABBITMQ_LISTENER_CONCURRENCY=1
SPRING_RABBITMQ_LISTENER_PREFETCH=10

# Mock HTTP sender (WireMock in docker-compose; host port 8081 maps to container 8080)
MOCK_SENDER_BASE_URL=http://mock-sender:8080
MOCK_SENDER_PATH=/send
MOCK_SENDER_MAX_ATTEMPTS=3
MOCK_SENDER_CONNECT_TIMEOUT_MS=5000
MOCK_SENDER_READ_TIMEOUT_MS=10000

# OTLP HTTP traces -> Jaeger all-in-one (Compose service "jaeger")
# - Inside Docker Compose, the app container must use the service hostname (not localhost):
MANAGEMENT_OTLP_TRACING_ENDPOINT=http://jaeger:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
# - From your host: Jaeger UI http://localhost:16686
# - From your host, OTLP HTTP (e.g. curl or a local agent): http://localhost:4318/v1/traces
